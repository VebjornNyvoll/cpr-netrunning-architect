<form class="nra-floor-edit-form">
  <div class="form-group">
    <label>{{localize (concat moduleId '.builder.dv')}}</label>
    <input type="number" name="dv" value="{{floor.dv}}" min="2" max="20" />
  </div>

  <div class="form-group">
    <label>{{localize (concat moduleId '.builder.content')}}</label>
    <select name="content">
      {{#each contentChoices}}
        <option value="{{@key}}" {{#if (eq @key ../floor.content)}}selected{{/if}}>{{this}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group nra-ice-select" {{#unless isBlackIce}}style="display:none"{{/unless}}>
    <label>{{localize (concat moduleId '.builder.blackIce')}}</label>
    <select name="blackice">
      <option value="">-- None --</option>
      {{#each iceChoices}}
        <option value="{{@key}}" {{#if (eq @key ../selectedIce)}}selected{{/if}}>{{this}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize (concat moduleId '.builder.branch')}}</label>
    <input type="checkbox" name="branch" {{#if floor.branch}}checked{{/if}} />
  </div>

  <div class="form-group">
    <label>{{localize (concat moduleId '.builder.description')}}</label>
    <textarea name="description" rows="3">{{floor.description}}</textarea>
  </div>
</form>
