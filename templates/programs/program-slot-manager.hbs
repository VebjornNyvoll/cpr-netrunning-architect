<div class="nra-programs">
  <header class="nra-programs-header">
    <h2><i class="fas fa-microchip"></i> {{localize (concat moduleId '.programs.title')}}</h2>
    {{#if cyberdeck}}
      <div class="nra-deck-info">
        <img src="{{cyberdeck.img}}" width="28" height="28" />
        <span class="nra-deck-name">{{cyberdeck.name}}</span>
        <span class="nra-slot-count">{{usedSlots}} / {{totalSlots}} {{localize (concat moduleId '.programs.slots')}}</span>
      </div>
    {{/if}}
  </header>

  {{#if cyberdeck}}
    <div class="nra-programs-section">
      <h3><i class="fas fa-bolt"></i> {{localize (concat moduleId '.programs.rezzed')}} ({{rezzedPrograms.length}})</h3>
      <div class="nra-program-grid">
        {{#each rezzedPrograms}}
          {{> "modules/cpr-netrunning-architect/templates/programs/program-card.hbs" this}}
        {{/each}}
      </div>
    </div>

    <div class="nra-programs-section">
      <h3><i class="fas fa-download"></i> {{localize (concat moduleId '.programs.installed')}} ({{installedPrograms.length}})</h3>
      <div class="nra-program-grid">
        {{#each installedPrograms}}
          {{> "modules/cpr-netrunning-architect/templates/programs/program-card.hbs" this}}
        {{/each}}
      </div>
    </div>

    {{#if emptySlots}}
      <div class="nra-programs-section">
        <div class="nra-program-grid">
          {{#each emptySlots}}
            {{> "modules/cpr-netrunning-architect/templates/programs/program-card.hbs" this}}
          {{/each}}
        </div>
      </div>
    {{/if}}
  {{else}}
    <div class="nra-empty-state">
      <i class="fas fa-exclamation-triangle"></i>
      <p>{{localize (concat moduleId '.programs.noCyberdeck')}}</p>
    </div>
  {{/if}}
</div>
